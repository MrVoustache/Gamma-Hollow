        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": {
            "Name": "minecraft:smooth_basalt"
          }
        }
      },

      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:y_above",
          "anchor": {
            "above_bottom": 660
          },
          "surface_depth_multiplier": -15,
          "add_stone_depth": false
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": {
            "Name": "minecraft:blackstone"
          }
        }
      },

      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:y_above",
          "anchor": {
            "above_bottom": 550
          },
          "surface_depth_multiplier": -15,
          "add_stone_depth": false
        },
        "then_run": {
          "type": "minecraft:block",
          "result_state": {
